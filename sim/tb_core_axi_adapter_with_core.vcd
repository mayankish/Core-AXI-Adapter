$var wire 4 ~$ s_wstrb [3:0] $end
$var wire 1 & s_wvalid $end
$var parameter 32 !% AW $end
$var parameter 32 "% AW_DELAY $end
$var parameter 32 #% B_DELAY $end
$var parameter 32 $% DW $end
$var parameter 32 %% R_DELAY $end
$var reg 8 &% ar_addr_r [7:0] $end
$var reg 8 '% aw_addr_r [7:0] $end
$var reg 1 (% aw_latched $end
$var reg 1 )% b_pending $end
$var reg 1 *% r_pending $end
$var reg 1 5 s_arready $end
$var reg 1 2 s_awready $end
$var reg 2 +% s_bresp [1:0] $end
$var reg 1 . s_bvalid $end
$var reg 32 ,% s_rdata [31:0] $end
$var reg 2 -% s_rresp [1:0] $end
$var reg 1 * s_rvalid $end
$var reg 1 ( s_wready $end
$var reg 32 .% w_data_r [31:0] $end
$var reg 1 /% w_latched $end
$var integer 32 0% ar_cnt [31:0] $end
$var integer 32 1% aw_cnt [31:0] $end
$var integer 32 2% b_cnt [31:0] $end
$var integer 32 3% r_cnt [31:0] $end
$upscope $end
$upscope $end
$enddefinitions $end
$comment Show the parameter values. $end
$dumpall
